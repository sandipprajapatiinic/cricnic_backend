PORT=3000
# 0.0.0.0 = LAN + emulator; 127.0.0.1 = this machine only
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/cricnic
# Firebase Admin: path to service account JSON, OR paste JSON as single line in FIREBASE_SERVICE_ACCOUNT_JSON
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
# Local dev only: bypass Firebase token verification (set true until service account JSON exists)
# NEVER set DEV_SKIP_AUTH=true on a public URL (e.g. Render) — anyone could use your API.
# DEV_SKIP_AUTH=true
# CORS_ORIGIN=http://localhost:8100
#
# Render / production: set MONGODB_URI, FIREBASE_SERVICE_ACCOUNT_JSON (or GOOGLE_APPLICATION_CREDENTIALS),
# DEV_SKIP_AUTH=false (omit), and optionally CORS_ORIGIN=https://your-frontend-domain.com
#
# GET /api/players, /api/teams, /api/matches (list), /api/matches/:id are public by default (no Bearer).
# To require Firebase for those too:
# REQUIRE_AUTH_EVERYWHERE=true
# Optional explicit opt-out of public lists: PUBLIC_API_READ=false
#
# Demo teams + players: npm run seed:demo
# Fix Team.players arrays from Player.teamId: npm run sync:team-refs
