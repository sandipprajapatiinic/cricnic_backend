PORT=3000
# 0.0.0.0 = LAN + emulator; 127.0.0.1 = this machine only
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/cricnic
# Firebase Admin: path to service account JSON, OR paste JSON as single line in FIREBASE_SERVICE_ACCOUNT_JSON
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
# Local dev only: bypass Firebase token verification (set true until service account JSON exists)
# DEV_SKIP_AUTH=true
# CORS_ORIGIN=http://localhost:8100
#
# Demo teams + players: npm run seed:demo
# Fix Team.players arrays from Player.teamId: npm run sync:team-refs
